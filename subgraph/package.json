{
  "name": "eternal-mint-subgraph",
  "license": "UNLICENSED",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "auth": "graph auth --studio",
    "deploy:dev": "graph deploy --studio eternalmint-pro-dev",
    "deploy:staging": "graph deploy --studio eternalmint-pro-staging --file subgraph.staging.yaml",
    "deploy:production": "graph deploy --studio eternalmint-pro --file subgraph.production.yaml",
    "create-local": "graph create --node http://localhost:8020/ eternalmint-pro",
    "remove-local": "graph remove --node http://localhost:8020/ eternalmint-pro",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 eternalmint-pro",
    "test": "graph test"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.97.1",
    "@graphprotocol/graph-ts": "0.38.1"
  },
  "devDependencies": {
    "matchstick-as": "0.5.0"
  }
}
